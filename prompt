appointments (id, patient_id FK, doctor_id FK, scheduled_at, end_time, type, status: pending|confirmed|completed|cancelled|no_show, reason, notes, payment_status: unpaid|paid|refunded, amount, zoom_meeting_id, zoom_join_url, zoom_start_url, zoom_password, timestamps)
